# ============================================================
# Required — what you actually set up
# ============================================================

# 1) LLM provider: "anthropic" (Claude) or "openai" — and the key for it.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# 2) Docs repo to open PRs in ("owner/repo") + a token that can push & open PRs there.
DOCS_REPO=acme/docs
DOCS_REPO_PAT=

# 3) Slack incoming webhook — used to announce the docs PR.
SLACK_WEBHOOK_URL=

# ============================================================
# Auto-provided by GitHub Actions — only set these for LOCAL runs
# ============================================================
# CODE_REPO=acme/code            # CI: github.repository
# GITHUB_TOKEN=                  # CI: built-in secrets.GITHUB_TOKEN
# PR_NUMBER=123                  # CI: github.event.pull_request.number
# DOCS_REPO_DIR=./docs-checkout  # CI: set by the docs checkout step
